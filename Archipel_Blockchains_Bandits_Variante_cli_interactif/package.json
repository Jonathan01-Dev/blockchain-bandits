{
  "name": "archipel",
  "version": "0.1.0",
  "description": "Archipel P2P local encrypted protocol prototype",
  "main": "src/cli/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/cli/index.js start",
    "start:web": "node src/cli/index.js start --web --web-port 8080 --web-only",
    "cli": "node src/cli/index.js",
    "clean:state": "bash scripts/clean_state.sh",
    "test:unit": "node --test tests/unit.test.js",
    "test:smoke": "node scripts/smoke.js",
    "test:smoke:multi": "node scripts/smoke_multi.js",
    "test:smoke:resume": "node scripts/smoke_resume.js",
    "test:smoke:retry": "node scripts/smoke_retry.js"
  }
}
